# 阿里云OSS配置
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
OSS_BUCKET=你的BucketName

# 服务端口
PORT=3000

# 视频公开访问的域名（OSS Bucket域名或自定义域名）
# 示例: https://your-bucket.oss-cn-hangzhou.aliyuncs.com
OSS_PUBLIC_DOMAIN=https://your-bucket.oss-cn-hangzhou.aliyuncs.com

# 本服务的外网访问地址（用于生成播放页链接）
# 本地测试填 http://localhost:3000，部署后填实际域名
APP_BASE_URL=http://localhost:3000
